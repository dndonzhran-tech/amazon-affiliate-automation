# Amazon Affiliate Automation - Environment Variables
# Copy this file to .env and fill in your actual values

# === Amazon Product API (via RapidAPI) ===
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=real-time-amazon-data.p.rapidapi.com

# === Amazon Affiliate Program ===
AMAZON_AFFILIATE_TAG=your-affiliate-tag-20
AMAZON_COUNTRY=US

# === Groq AI (Content Generation) ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# === Content Settings ===
LANGUAGE=en
PRODUCT_CATEGORY=electronics
MAX_POSTS_PER_RUN=3

# === Social Media Platform 1 (e.g., Twitter/X API) ===
PLATFORM1_API_URL=https://api.twitter.com/2/tweets
PLATFORM1_API_TOKEN=your_platform1_token_here

# === Social Media Platform 2 (e.g., Facebook Page API) ===
PLATFORM2_API_URL=https://graph.facebook.com/v18.0/me/feed
PLATFORM2_API_TOKEN=your_platform2_token_here

# === Notifications (Telegram / Slack webhook) ===
NOTIFICATION_WEBHOOK_URL=https://api.telegram.org/botYOUR_BOT_TOKEN/sendMessage?chat_id=YOUR_CHAT_ID
