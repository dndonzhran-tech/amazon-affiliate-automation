        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ platform: 'telegram', text: '📊 التقرير اليومي:\\n\\n' + '✅ منشورات اليوم: ' + $json.posts_today + '\\n' + '👁️ المشاهدات: ' + $json.impressions + '\\n' + '🔗 النقرات: ' + $json.clicks + '\\n' + '💰 الأرباح المقدرة: $' + $json.estimated_revenue + '\\n\\n' + '🏆 أفضل منتج: ' + ($json.top_product || 'لا يوجد'), parse_mode: 'HTML' }) }}"
      },
      "id": "send-daily-report",
      "name": "📩 إرسال التقرير",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [500, 900]
    },
    {
      "parameters": {
