        "path": "add-product",
        "options": {}
      },
      "id": "add-product-webhook",
      "name": "➕ إضافة منتج (Webhook)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [0, 1200],
      "webhookId": "affiliate-add-product"
    },
    {
      "parameters": {
